# ─────────────────────────────────────────────────────────────
#  .env.example — скопіюйте в .env і заповніть своїми значеннями
# ─────────────────────────────────────────────────────────────

# ОБОВ'ЯЗКОВО змінити на продакшні!
DEBUG=False
SECRET_KEY=замінити-на-довгий-випадковий-рядок-мінімум-50-символів

# Ваш домен або IP сервера (через кому якщо кілька)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# База даних (SQLite за замовчуванням)
DATABASE_URL=sqlite:///db.sqlite3

# Для PostgreSQL (якщо захочете перейти):
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
