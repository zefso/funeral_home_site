"fingerprints"

#: .\templates\core\service_list.html:83
msgid "kleine Fotos"
msgstr ""
"small photos"

#: .\templates\core\service_list.html:85
msgid "Alle Stücke entstehen in liebevoller Handarbeit."
msgstr ""
"All pieces are lovingly handcrafted."
